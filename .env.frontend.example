# Backend API URL
BANANA_LECTURE_API_BASE_URL=http://backend:8000

# Runtime base path for the application (e.g., /banana, empty for root)
# This allows flexible path switching without rebuilding
RUNTIME_BASE_PATH=

# AI planner configuration for /api/chat.
# Fill OPENAI_API_KEY to enable chat-based PPT planning.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.moonshot.cn/v1
OPENAI_MODEL=kimi-k2.5
